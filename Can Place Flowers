class Solution {
    public boolean canPlaceFlowers(int[] flowerbed, int n) {
        
        int count=0;
        for(int i=0;i<flowerbed.length;i++)
        {
            if(flowerbed[i] == 0 && ((i==0 || flowerbed[i-1] == 0) && (i == flowerbed.length-1 || flowerbed[i+1] == 0)))
            {
                count+=1;
                flowerbed[i] = 1;
            }
        }
        return count >= n;
    }
}

# whenever we are check (i-1) and (i+1) then we have to guard it with i==0 and i==a.length-1, so we don't get IndexOutOfBounds error

# i==0 will be checked only once when i=0, for the rest of the iterations i==0 will be False
# i==a.length-1 will be checked once when it is the last element of an array, for the rest of the iterations i==a.length-1 will be False
