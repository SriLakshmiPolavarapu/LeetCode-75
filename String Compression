class Solution {
    public int compress(char[] chars) {
        
        int read=0;
        int write=0;

        while(read < chars.length)
        {
            int count=0;
            char current = chars[read];
        
            while(read < chars.length && current == chars[read])
            {
                count++;
                read++;
            }
        
            // cond 1
            if(count == 1)
            {
                chars[write++] = current;
            }
            // if count > 1 cond
            else
            {
                chars[write++] = current;
                String str = String.valueOf(count);
                for(char digit : str.toCharArray())
                {
                    chars[write++] = digit;
                }
            }
        }
        return write;
    }
}

